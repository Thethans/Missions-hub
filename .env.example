# Copy this file to .env and fill in real values. Never commit .env itself.

# Get free at https://joshuaproject.net/api/register
JP_API_KEY=

# Get free at https://supabase.com after creating a project (Settings > API)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side key for the sync-opportunities scraper (Settings > API > service_role)
# Also add as GitHub Actions secret: SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
