# Copy this file to .env and fill in real values. Never commit .env itself.

# Get free at https://joshuaproject.net/api/register
JP_API_KEY=

# Get free at https://supabase.com after creating a project (Settings > API)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side key for the sync-opportunities scraper (Settings > API > service_role)
# Also add as GitHub Actions secret: SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Opportunities Explorer: static snapshot (public/data/opportunities-fallback.json)
# is always the primary data source. Set to "true" to also fire a background
# Supabase freshness check on top of it (recommended for dev, leave unset/false
# in prod so production only ever pays for the one CDN-cached fetch).
VITE_ENABLE_FRESH_FETCH=

# Canonical site host used for every page's canonical/OG/twitter tags (see
# src/hooks/usePageMeta.js). Leave unset to use the current
# https://missions-hub.vercel.app default. Set this instead of editing code
# when the custom domain (P3-A) is ready — index.html's static tags and
# public/sitemap.xml still need a manual one-time edit, since neither can
# read an env var at runtime.
VITE_SITE_URL=
